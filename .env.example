# Neon PostgreSQL — use pooled for app, unpooled for migrations
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Auth — generate with: openssl rand -base64 64
JWT_SECRET=change_me_at_least_32_chars_long

# CORS origin (your Vercel deployment URL)
CORS_ORIGIN=https://your-app.vercel.app
